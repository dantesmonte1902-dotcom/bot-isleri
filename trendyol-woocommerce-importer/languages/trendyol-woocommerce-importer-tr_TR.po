#: admin/settings-page.php
msgid "⚙️ Plugin Settings"
msgstr "⚙️ Plugin Ayarları"

msgid "Permissions"
msgstr "İzinler"

msgid "Who can import products?"
msgstr "Ürünleri kimler içe aktarabilir?"

msgid "Who can sync products?"
msgstr "Ürünleri kimler senkronize edebilir?"

msgid "Select the minimum user role required to import products."
msgstr "Ürünleri içe aktarmak için gereken minimum kullanıcı rolünü seçin."

msgid "Select the minimum user role required to sync products with Trendyol."
msgstr "Ürünleri Trendyol ile senkronize etmek için gereken minimum kullanıcı rolünü seçin."

msgid "🔄 Auto Synchronization"
msgstr "🔄 Otomatik Senkronizasyon"

msgid "Enable automatic synchronization"
msgstr "Otomatik senkronizasyonu etkinleştir"

msgid "If enabled, products will be automatically synced at the interval specified below."
msgstr "Etkinleştirilirse, ürünler aşağıda belirtilen aralıkta otomatik olarak senkronize edilecektir."

msgid "Sync Interval"
msgstr "Senkronizasyon Aralığı"

msgid "Hourly"
msgstr "Saatlik"

msgid "Twice Daily"
msgstr "Günde İki Kez"

msgid "Daily"
msgstr "Günlük"

msgid "Weekly"
msgstr "Haftalık"

msgid "📊 Sync Options"
msgstr "📊 Senkronizasyon Seçenekleri"

msgid "Sync prices from Trendyol"
msgstr "Trendyol'dan fiyatları senkronize et"

msgid "Price Markup (%)"
msgstr "Fiyat Işaretlemesi (%)"

msgid "Add a percentage markup to Trendyol prices. Leave 0 for no markup."
msgstr "Trendyol fiyatlarına yüzdelik bir işaretleme ekleyin. İşaretleme yok için 0 bırakın."

msgid "Sync stock status from Trendyol"
msgstr "Trendyol'dan stok durumunu senkronize et"

msgid "If enabled, stock status will be updated based on Trendyol availability."
msgstr "Etkinleştirilirse, stok durumu Trendyol kullanılabilirliğine göre güncellenecektir."

msgid "Sync descriptions from Trendyol"
msgstr "Trendyol'dan açıklamaları senkronize et"

msgid "📥 Import Options"
msgstr "📥 İçe Aktarma Seçenekleri"

msgid "Maximum number of images to import"
msgstr "İçe aktarılacak maksimum resim sayısı"

msgid "Limit the number of product images downloaded from Trendyol."
msgstr "Trendyol'dan indirilen ürün resmilerinin sayısını sınırlayın."

msgid "🧹 Maintenance"
msgstr "🧹 Bakım"

msgid "Keep logs for (days)"
msgstr "Günlükleri (gün) tutun"

msgid "Old logs will be automatically deleted after this period."
msgstr "Eski günlükler bu dönemden sonra otomatik olarak silinecektir."

msgid "🔗 Advanced - Webhooks"
msgstr "🔗 Gelişmiş - Web Kancaları"

msgid "Enable webhook notifications"
msgstr "Web kancası bildirimlerini etkinleştir"

msgid "Webhook URL"
msgstr "Web Kancası URL'si"

msgid "Sync results will be sent to this URL as POST requests."
msgstr "Senkronizasyon sonuçları bu URL'ye POST istekleri olarak gönderilecektir."

msgid "🐛 Debug"
msgstr "🐛 Hata Ayıklama"

msgid "Enable debug mode"
msgstr "Hata ayıklama modunu etkinleştir"

msgid "Enable detailed logging for troubleshooting. Check error logs for details."
msgstr "Sorun giderme için ayrıntılı günlüğü etkinleştirin. Ayrıntılar için hata günlüklerini kontrol edin."

msgid "💾 Save Settings"
msgstr "💾 Ayarları Kaydet"

