#: trendyol-woocommerce-importer.php
msgid "Trendyol WooCommerce Importer requires WooCommerce to be installed and activated."
msgstr "Trendyol WooCommerce İçe Aktarıcı, WooCommerce'in kurulu ve etkin olmasını gerektirir."

#: includes/class-scraper.php
msgid "Only Trendyol.com product links are allowed."
msgstr "Yalnızca Trendyol.com ürün bağlantılarına izin verilir."

msgid "Product page could not be retrieved from Trendyol! Error:"
msgstr "Ürün sayfası Trendyol'dan alınamadı! Hata:"

